{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Worktree Manager",
  "version": "0.0.7",
  "identifier": "com.git-worktree-manager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Worktree Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost ws: http: https: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwM0E2NUVFNjQ0NTQxRjEKUldUeFFVVms3bVU2WUw3TkM2Z3VLVFFjTDJZRFlydk00dWlMeVFveFpPelpBeGQ5WE9KYU5VdmMK",
      "endpoints": [
        "https://github.com/zhuSilence/git-worktree-manager/releases/latest/download/{{target}}-{{arch}}.json"
      ]
    }
  }
}